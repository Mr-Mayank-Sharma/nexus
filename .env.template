# NexusShip Environment Configuration
# SECURITY: No secrets have default values. Generate strong unique values for each environment.
# Copy this file to .env and fill in ALL required values before starting the application.

# Database (required - no default)
DB_PASSWORD=

# JWT (required - no default, must be at least 32 characters)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Grafana (required - no default)
GRAFANA_ADMIN_PASSWORD=

# CORS (comma-separated origins)
CORS_ORIGINS=https://yourdomain.com

# Kafka (usually defaults are fine in Docker)
# SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
