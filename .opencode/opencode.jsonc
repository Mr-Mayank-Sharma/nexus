{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "atlassian-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.atlassian.com/v1/sse"]
    },
    "github-mcp-server": {
      "type": "local",
      "enabled": false,
      "command": ["docker", "run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "grafana-dev": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://grafana-uat-mcp.hotwaxsystems.com/sse"]
    },
    "grafana-chelan": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://chelan-grafana-mcp.hotwaxsystems.com/sse"]
    },
    "qwen-coder": {
      "type": "local",
      "command": ["node", "/home/mayanksharma/Desktop/sandbox/chelan/index.js"],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434",
        "QWEN_MODEL": "qwen2.5-coder:3b"
      }
    }
  }
}
